modules = ["python-3.11"]

  [deployment]
  deploymentTarget = "static"
  publicDir = "."

  [workflows]
  runButton = "Static Webpage"

  [[workflows.workflow]]
  name = "Static Webpage"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "python3 -m http.server ${PORT:-3000}"
  waitForPort = 3000

  [workflows.workflow.metadata]
  outputType = "webview"
  