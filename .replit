modules = ["python-3.11"]

  [deployment]
  deploymentTarget = "static"
  publicDir = "."

  [workflows]
  runButton = "Static Webpage"

  [[workflows.workflow]]
  name = "Static Webpage"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "python3 -m http.server ${PORT:-3000}"
  waitForPort = 3000

  [workflows.workflow.metadata]
  outputType = "webview"

[agent]
expertMode = true

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 25422
externalPort = 3001
  